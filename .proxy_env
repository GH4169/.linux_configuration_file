# 设置 HTTP/HTTPS 全局代理
# export http_proxy="http://10.4.1.230:7890"
# export https_proxy="http://10.4.1.230:7890"

# export http_proxy="http://127.0.0.1:7897"
# export https_proxy="http://127.0.0.1:7897"
# export all_proxy="socks5://127.0.0.1:7897"

# 动态获取 Windows 宿主机的 IP 地址
# export host_ip=$(cat /etc/resolv.conf | grep "nameserver" | cut -f 2 -d " ")
export host_ip=$(ip route show default | awk '{print $3}')
local proxy_port=7897
export http_proxy="http://$host_ip:$proxy_port"
export https_proxy="http://$host_ip:$proxy_port"
export all_proxy="socks5://$host_ip:$proxy_port"
echo -e "WSL 终端代理已开启 (宿主机 IP: $host_ip)"

# 设置不用走代理的地址 (内网地址不中转)
